# PostHog telemetry
# Set to false to disable all telemetry events.
VITE_ENABLE_TELEMETRY=true

# Project API key (phc_...)
VITE_POSTHOG_KEY=

# PostHog ingestion host (US region shown below)
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional app version tag for event properties
VITE_APP_VERSION=dev
